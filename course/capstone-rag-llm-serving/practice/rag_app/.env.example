# 캡스톤 RAG API 로컬 실행용 환경변수 — 본 파일을 .env 로 복사 후 사용합니다.
#
# Day 5 (로컬 개발) 가정:
#   Terminal A: kubectl port-forward -n rag-llm svc/qdrant 6333:6333
#   Terminal B: kubectl port-forward -n rag-llm svc/vllm   8000:8000
#   Terminal C: cp .env.example .env && uvicorn main:app --reload --port 8001
#
# Day 6 (클러스터 배포) 시점에는 본 값들이 ConfigMap (32-rag-api-configmap.yaml) 으로 옮겨가고,
# QDRANT_URL / LLM_BASE_URL 은 클러스터 내부 DNS 형태로 바뀝니다.

# Qdrant (Day 1 의 StatefulSet — Day 2 인덱싱이 적재한 컬렉션)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag-docs

# 임베딩 모델 (Day 2 결정 — 한국어 다수 자료 대응, 384 dim)
EMBED_MODEL=intfloat/multilingual-e5-small

# vLLM (Day 4 의 Deployment — served-model-name 과 LLM_MODEL 이 *완전 동일* 해야 합니다)
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=microsoft/phi-2

# 검색 기본 top_k (요청 본문 top_k 가 None 이면 본 값을 사용)
TOP_K=3
