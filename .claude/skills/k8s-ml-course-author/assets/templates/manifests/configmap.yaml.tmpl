# м¶”лЎ  н•ҳмқҙнҚјнҢҢлқјлҜён„° ConfigMap
# Podм—җм„ң envFrom лҳҗлҠ” volumeMountлЎң л§ҲмҡҙнҠё
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{APP_NAME}}-config
  labels:
    app: {{APP_NAME}}
data:
  # нҷҳкІҪ ліҖмҲҳлЎң мЈјмһ…н•  н•ӯлӘ© (envFrom)
  MAX_LENGTH: "{{MAX_LENGTH}}"            # мҳҲ: "512"
  TOP_K: "{{TOP_K}}"                      # мҳҲ: "5"
  BATCH_SIZE: "{{BATCH_SIZE}}"            # мҳҲ: "32"
  LOG_LEVEL: "INFO"

  # нҢҢмқјлЎң л§ҲмҡҙнҠён•  н•ӯлӘ© (volumeMount with subPath лҳҗлҠ” м „мІҙ)
  inference.yaml: |
    model:
      name: {{MODEL_NAME}}
      max_length: {{MAX_LENGTH}}
      top_k: {{TOP_K}}
    serving:
      batch_size: {{BATCH_SIZE}}
      timeout_seconds: 30
