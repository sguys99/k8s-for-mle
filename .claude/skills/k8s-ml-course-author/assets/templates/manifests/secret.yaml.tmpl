# 자격증명 Secret 템플릿
# 운영에서는 SealedSecret 또는 외부 KMS(예: External Secrets Operator) 권장.
# 학습용으로는 stringData로 평문 작성 후 클러스터에 적용해도 됩니다.
apiVersion: v1
kind: Secret
metadata:
  name: {{APP_NAME}}-secrets
  labels:
    app: {{APP_NAME}}
type: Opaque
stringData:
  # HuggingFace 토큰 (private 모델 접근용)
  HF_TOKEN: "{{HF_TOKEN_PLACEHOLDER}}"     # TODO: 실제 토큰으로 교체

  # OpenAI 키 (RAG에서 OpenAI 호출 시)
  # OPENAI_API_KEY: "{{OPENAI_API_KEY_PLACEHOLDER}}"

  # S3 자격증명 (모델 가중치 다운로드용)
  # AWS_ACCESS_KEY_ID: ""
  # AWS_SECRET_ACCESS_KEY: ""

# ⚠️ git에 평문으로 커밋하지 마세요. .gitignore 필수.
